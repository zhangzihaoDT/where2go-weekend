# 高德 Web Service API，用于 Python 采集 POI
AMAP_API_KEY=

# 高德 API Secret（签名验证），仅在开启了签名验证时需要
# 可在高德开放平台 → 应用管理 → 添加/查看密钥 中找到
# AMAP_API_SECRET=

# 高德 JS API Key，用于 HTML 地图展示
# 注意：静态 HTML 中暴露 JS API key 只适合本地 MVP
# 公开发布时需要重新设计 key 管理方式
# AMAP_JS_API_KEY=

# 高德 JS API 安全密钥（部分 key 配置需要）
# AMAP_SECURITY_JS_CODE=
